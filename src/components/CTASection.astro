---
interface Props {
  lang: "en" | "zh";
  title: string;
  description: string;
  buttonText: string;
}

const { lang, title, description, buttonText } = Astro.props;
---

<section class="cta-section">
  <div class="container">
    <div class="cta-card breathe-bg">
      <h2 data-reveal="fade">{title}</h2>
      <p data-reveal="fade">{description}</p>
      <a href={`/${lang}/contact/`} class="btn btn-primary btn-lg btn-ripple" data-reveal="scale">{buttonText}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--section-padding) 0;
    background: var(--white);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--purple-deep), var(--purple));
    border-radius: var(--radius-lg);
    padding: 64px 48px;
    text-align: center;
    color: var(--white);
  }

  .cta-card h2 {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white);
  }

  .cta-card p {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 32px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-lg {
    padding: 16px 40px;
    font-size: 16px;
    background: var(--white) !important;
    color: var(--purple-deep) !important;
    border-color: var(--white) !important;
  }

  .btn-lg:hover {
    background: var(--purple-surface) !important;
    color: var(--purple) !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 640px) {
    .cta-card {
      padding: 40px 24px;
    }

    .cta-card h2 {
      font-size: 24px;
    }
  }
</style>
