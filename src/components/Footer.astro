---
const email = "josh@ymys0769.com";
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h4>YUANMEI PRINTING</h4>
        <p>Custom packaging manufacturer — Dongguan, Guangdong, China</p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/products/">Products · Cases</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/faq/">FAQ</a></li>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li>Email: <a href={`mailto:${email}`}>{email}</a></li>
          <li>WhatsApp: +86 13532861588</li>
          <li>Dongguan, Guangdong, China</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2008–2026 Guangdong Dongguan Yuanmei Printing Factory. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--purple-bg); color: #94a3b8; padding: 64px 0 32px; }
  .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 48px; margin-bottom: 40px; max-width: 1100px; margin-left: auto; margin-right: auto; padding: 0 24px; }
  .footer h4 { color: var(--white); font-size: 15px; font-weight: 700; margin-bottom: 16px; }
  .footer p { font-size: 14px; line-height: 1.7; }
  .footer ul { list-style: none; padding: 0; }
  .footer ul li { margin-bottom: 8px; font-size: 14px; }
  .footer a { color: #94a3b8; text-decoration: none; transition: color 0.2s; }
  .footer a:hover { color: var(--purple-light); }
  .footer-bottom { border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 24px; text-align: center; font-size: 13px; max-width: 1100px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  @media (max-width: 768px) { .footer-grid { grid-template-columns: 1fr; gap: 32px; } }
</style>
