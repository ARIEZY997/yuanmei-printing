---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Thank You — Yuanmei Printing" description="Your message has been received. We'll reply within 24 hours." lang="en" currentPath="/success/">
<main class="thanks-page">
  <div class="thanks-card">
    <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="30" stroke="var(--purple-light)" stroke-width="2"/><path d="M20 32L28 40L44 24" stroke="var(--purple-light)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <h1>Inquiry Received</h1>
    <p>Thank you for contacting YMBOX.<br>Our packaging specialist will reply within <strong>24 hours</strong>.</p>
    <div class="thanks-divider"></div>
    <p class="thanks-download">While you wait, download our company catalog:</p>
    <a href="/catalog/" class="btn btn-primary">View Company Catalog</a>
    <p class="thanks-contact">WhatsApp: +86 13532861588<br>Email: josh@ymys0769.com</p>
  </div>
</main>
</BaseLayout>

<style>
.thanks-page{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0a0a0f;padding:24px}
.thanks-card{text-align:center;max-width:400px}
.thanks-card h1{font-family:var(--font-display);font-size:32px;font-weight:800;color:#e0dce8;margin:20px 0 12px}
.thanks-card p{font-size:16px;color:#9ca3af;line-height:1.7;margin-bottom:16px}
.thanks-card strong{color:var(--purple-light)}
.thanks-divider{width:40px;height:1px;background:var(--purple-light);margin:28px auto;opacity:0.4}
.thanks-download{font-size:14px!important;margin-bottom:20px!important}
.thanks-contact{font-size:13px!important;color:#6b7280!important;margin-top:28px!important;line-height:2}
</style>
