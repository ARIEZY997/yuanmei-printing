---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found | Yuanmei Printing" description="The page you're looking for doesn't exist." lang="en" currentPath="">
  <main class="page-404">
    <div class="c404">
      <h1>404</h1>
      <div class="c404-line"></div>
      <p>This page doesn't exist.<br>But every box we make does.</p>
      <a href="/en/" class="btn btn-primary btn-ripple">Back to Home</a>
    </div>
  </main>
</BaseLayout>

<style>
.page-404{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0a0a0f;color:#e0dce8;text-align:center;padding:24px}
.c404 h1{font-family:var(--font-display);font-size:clamp(80px,20vw,180px);font-weight:900;color:var(--purple-light);line-height:1;letter-spacing:-6px;opacity:0.3;margin-bottom:16px}
.c404-line{width:60px;height:2px;background:var(--purple-light);margin:0 auto 24px}
.c404 p{font-size:17px;color:#6b7280;line-height:1.6;margin-bottom:36px}
</style>
