---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CTASection from "../components/CTASection.astro";
import en from "../i18n/en.json";

const t = en;
const currentPath = "/about/";
---

<BaseLayout
  title={`About — ${t.site.title}`}
  description="18 years of packaging manufacturing. ISO-certified factory with 5 large presses, Komori & Roland equipment, FDA & EU food contact compliant. Dongguan, China."
  lang="en"
  currentPath={currentPath}
>
  <Nav lang="en" currentPath={currentPath} />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <h1 data-reveal="fade">{t.about.title}</h1>
        <p data-reveal="fade">{t.about.description}</p>
      </div>
    </section>

    <!-- Story -->
    <section class="section">
      <div class="container">
        <div class="story-layout">
            <div class="story-content" data-reveal="left">
            <span class="section-label">Who We Are</span>
            <h2 class="section-title">{t.about.story.title}</h2>
            <p>{t.about.story.content}</p>
          </div>
          <div class="story-img" data-reveal="right">
            <img src="/images/工厂内图.png" alt="Yuanmei Printing factory interior" class="story-real-img" />
          </div>
        </div>
      </div>
    </section>

    <!-- Team Stats -->
    <section class="stats-bar">
      <div class="container">
        {t.about.team.items.map((item) => (
          <div class="stat-item">
            <div class="stat-num">{item.number}</div>
            <div class="stat-lbl">{item.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Machinery -->
    <section class="section section-alt">
      <div class="container">
        <span class="section-label">Equipment</span>
        <h2 class="section-title">{t.about.machinery.title}</h2>
        <p class="section-desc">All production processes — from prepress to finishing — completed in-house</p>
        <div class="machinery-grid" data-reveal-stagger="120">
          {t.about.machinery.items.map((item, i: number) => {
            const mImgs = ["/images/小森.jpg","/images/多兰机全景.jpg","/images/高爆.jpg","/images/640.jpg",null,null];
            return (
            <div class="machinery-card hover-lift glow-hover" data-reveal>
              {mImgs[i] && <div class="machinery-thumb"><img src={mImgs[i]} alt={item.name} /></div>}
              <h3>{item.name}</h3>
              <p>{item.desc}</p>
            </div>
          )})}
        </div>
      </div>
    </section>

    <!-- Certifications -->
    <section class="section section-alt">
      <div class="container">
        <span class="section-label">Trust & Quality</span>
        <h2 class="section-title">{t.about.certifications.title}</h2>
        <div class="cert-grid-large" data-reveal-stagger="150">
          {t.about.certifications.items.map((item, i: number) => {
            const certImgs = ["/images/验证资质1.png","/images/验证资质2.png","/images/验证资质3.png","/images/验证资质4.png"];
            return (
            <div class="cert-card-large hover-lift" data-reveal>
              {certImgs[i] && <div class="cert-img-wrap"><img src={certImgs[i]} alt={item.name} class="cert-img-large" /></div>}
              <div class="cert-info-large">
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
            </div>
          )})}
        </div>
      </div>
    </section>

    <CTASection
      lang="en"
      title="See Our Factory in Action?"
      description="We welcome factory visits. Contact us to schedule a tour or request detailed equipment specifications."
      buttonText="Schedule a Visit"
    />
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .page-hero {
    padding: 140px 0 64px;
    background: linear-gradient(135deg, var(--purple-bg), #2D1250);
    color: var(--white);
    text-align: center;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .page-hero p {
    font-size: 17px;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Story */
  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .story-content p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: 16px;
  }

  .story-real-img { width:100%; height:100%; object-fit:cover; border-radius:var(--radius-lg); }
.machinery-thumb { height:180px; border-radius:8px; overflow:hidden; margin-bottom:14px; }
.machinery-thumb img { width:100%; height:100%; object-fit:cover; }
.img-placeholder {
    background: linear-gradient(135deg, #f0edf7, #e8e0f5);
    border-radius: var(--radius-lg);
    height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple);
    font-weight: 600;
    font-size: 15px;
  }

  /* Stats Bar */
  .stats-bar {
    background: var(--purple);
    padding: 48px 0;
  }

  .stats-bar .container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 6px;
  }

  .stat-lbl {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  /* Machinery */
  .machinery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }

  .machinery-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 28px;
    transition: box-shadow 0.2s;
  }

  .machinery-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--purple-light);
  }

  .machinery-card h3 {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--purple-deep);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .machinery-card h3::before {
    content: "⚙";
    font-size: 18px;
  }

  .machinery-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Certifications Large */
  .cert-grid-large {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }

  .cert-card-large {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cert-img-wrap {
    height: 260px;
    overflow: hidden;
    background: #f8f7ff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .cert-img-large {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .cert-info-large {
    padding: 24px;
  }

  .cert-info-large h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .cert-info-large p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .page-hero h1 {
      font-size: 28px;
    }

    .stats-bar .container {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .stat-num {
      font-size: 32px;
    }
  }
</style>
