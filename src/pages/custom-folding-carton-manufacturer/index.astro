---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
const p = "/custom-folding-carton-manufacturer/";
---
<BaseLayout title="Custom Folding Carton Manufacturer China — YMBOX" description="YMBOX: professional custom folding carton manufacturer in Dongguan China. Food, cosmetic, luxury boxes. FDA & FSC certified. Free sample & quote." lang="en" currentPath={p}>
<Nav lang="en" currentPath={p} />
<main class="page"><section class="page-hero"><div class="container"><h1>Custom Folding Carton Manufacturer</h1><p>Premium folding cartons for global brands — made in Dongguan, China since 2008</p></div></section>
<section class="section section-alt"><div class="container">
<h2>Why Choose YMBOX for Folding Cartons</h2>
<div class="kw-grid">
<div class="kw-card"><h3>40+ Countries</h3><p>We export custom packaging to brands across North America, Europe, Asia-Pacific, and the Middle East.</p></div>
<div class="kw-card"><h3>80+ Craftsmen</h3><p>Skilled workers with decades of combined experience in folding carton production and quality control.</p></div>
<div class="kw-card"><h3>5 Printing Presses</h3><p>Komori G40, Roland 700, KBA — in-house production means faster turnaround and consistent quality.</p></div>
<div class="kw-card"><h3>FDA & FSC Certified</h3><p>Food-grade materials available. FSC-certified paper for sustainable packaging solutions.</p></div>
</div>
</div></section>
<section class="section"><div class="container">
<h2>Folding Carton Capabilities</h2>
<div class="kw-grid">
{[{t:"Materials",i:["Grey Board 1200gsm","Coated Art Paper","Kraft Paper","Duplex Board","Food-Grade FDA Stock"]},{t:"Structures",i:["Straight Tuck End","Reverse Tuck End","Drawer Box","Magnetic Closure","Custom Die-Cut"]},{t:"Finishes",i:["Hot Foil Stamping","Spot UV","Matte/Gloss Lamination","Embossing/Debossing","Soft Touch Coating"]},{t:"MOQ & Lead Time",i:["MOQ: 50 pieces","Sample: Free, 3-5 days","Production: 7-15 days","Shipping: Sea/Air/DDP","File: AI, PDF, CDR"]}].map((s)=>(<div class="kw-card"><h3>{s.t}</h3><ul>{s.i.map((i)=><li>{i}</li>)}</ul></div>))}
</div>
</div></section>
<section class="section section-alt"><div class="container"><h2>Ready to Start Your Folding Carton Project?</h2><p style="text-align:center;color:#9ca3af;margin-bottom:24px">Tell us about your packaging needs. We'll reply within 24 hours with a free quotation.</p><div style="text-align:center"><a href="/contact/" class="btn btn-primary btn-ripple">Request a Quote</a></div></div></section>
</main>
<Footer/>
</BaseLayout>
<style>.page{background:#0a0a0f;color:#e0dce8}.page-hero{padding:140px 0 64px;background:linear-gradient(135deg,var(--purple-bg),#2D1250);color:var(--white);text-align:center}.page-hero h1{font-family:var(--font-display);font-size:clamp(28px,5vw,48px);font-weight:800;margin-bottom:12px}.page-hero p{font-size:17px;color:#94a3b8}.section{padding:80px 0}.section-alt{background:#110d1a}.container{max-width:1100px;margin:0 auto;padding:0 24px}.section h2{font-family:var(--font-display);font-size:clamp(24px,4vw,36px);font-weight:800;color:#e0dce8;margin-bottom:32px;text-align:center}.kw-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px}.kw-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px}.kw-card h3{font-size:16px;font-weight:700;color:var(--purple-light);margin-bottom:12px}.kw-card p{font-size:14px;color:#9ca3af;line-height:1.7}.kw-card ul{list-style:none;padding:0}.kw-card li{font-size:14px;color:#9ca3af;padding:4px 0}.kw-card li::before{content:"→ ";color:var(--purple-light)}@media(max-width:640px){.page-hero h1{font-size:24px}}</style>
