---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
const p = "/capabilities/";
---
<BaseLayout title="Manufacturing Capabilities — YMBOX" description="YMBOX manufacturing capabilities: offset printing, foil stamping, embossing, die cutting, gluing. Komori, Roland, KBA presses. ISO 9001, FDA, FSC certified." lang="en" currentPath={p}>
<Nav lang="en" currentPath={p} />
<main class="page"><section class="page-hero"><div class="container"><h1>Manufacturing Capabilities</h1><p>Everything under one roof — from prepress to delivery</p></div></section>

<section class="section section-alt"><div class="container">
<h2>Printing</h2>
<div class="cap-grid">
{[{t:"Komori Lithrone G40",d:"5-color offset press with coater. Sheet size up to 720×1,030mm. High-speed precision for medium to large production runs. Industry-leading color consistency."},{t:"Roland 700 Series",d:"4-color offset press. Quick job changeover for short to medium runs. Trusted globally for print quality and reliability."},{t:"KBA Press",d:"German-engineered for premium quality. Ideal for high-end packaging that demands flawless reproduction."}].map((m)=>(<div class="cap-card"><h3>{m.t}</h3><p>{m.d}</p></div>))}
</div>
</div></section>

<section class="section"><div class="container">
<h2>Finishing & Post-Press</h2>
<div class="cap-grid">
{[{t:"Hot Foil Stamping",d:"Gold, silver, rose gold, and holographic foil. Cylinder and platen machines for precise metallic application across any box surface."},{t:"Spot UV Coating",d:"Selective high-gloss highlights. Perfect for logos, patterns, and design accents. Applied with pinpoint precision."},{t:"Embossing & Debossing",d:"Raised or recessed 3D effects. Blind embossing available for subtle elegance, or combined with foil for maximum impact."},{t:"Matte & Gloss Lamination",d:"Full-sheet lamination in matte or gloss. Protects print while enhancing tactile feel. Soft touch coating also available."},{t:"Die Cutting & Creasing",d:"3 automatic die-cutting lines. Custom shapes, windows, and precision creasing. Every cut exactly where it should be."},{t:"Gluing & Assembly",d:"2 high-speed folder-gluer lines with auto quality inspection. Hand-finishing for complex structures and luxury boxes."}].map((m)=>(<div class="cap-card"><h3>{m.t}</h3><p>{m.d}</p></div>))}
</div>
</div></section>

<section class="section section-alt"><div class="container">
<h2>Prepress & Design</h2>
<div class="cap-grid">
{[{t:"Structural Design",d:"Our engineers create production-ready dielines from your concept. Precise to 0.1mm, with structural testing for strength and fit."},{t:"CTP Plate Making",d:"Computer-to-plate technology. Direct laser imaging for razor-sharp dot reproduction. Faster setup, sharper results."},{t:"Color Management",d:"Pantone matching on all presses. Digital proofs before production. Color consistency across every sheet and every run."},{t:"Artwork Support",d:"We accept AI, PDF, CDR, EPS files. Our prepress team reviews every file and flags issues before printing begins."}].map((m)=>(<div class="cap-card"><h3>{m.t}</h3><p>{m.d}</p></div>))}
</div>
</div></section>

<section class="section"><div class="container">
<h2>Quality Control</h2>
<div class="cap-grid">
{[{t:"Incoming Material Inspection",d:"Every batch of paper and board is checked for GSM, thickness, and surface quality before production."},{t:"In-Process QC",d:"Spot checks at every stage — printing, die-cutting, gluing. Deviations caught and corrected immediately."},{t:"Final Inspection",d:"Every box hand-inspected before packing. 80+ skilled craftsmen. Zero defects, zero surprises."},{t:"Certifications",d:"ISO 9001:2015 certified quality management. FDA and EU food contact compliant materials. FSC-certified sustainable paper available."}].map((m)=>(<div class="cap-card"><h3>{m.t}</h3><p>{m.d}</p></div>))}
</div></div></section>

<section class="section section-alt"><div class="container"><h2>Ready to Work With Us?</h2><p style="text-align:center;color:#9ca3af;margin-bottom:24px">18 years · 5 presses · 80+ craftsmen · 40+ countries</p><div style="text-align:center"><a href="/contact/" class="btn btn-primary btn-ripple">Request a Quote</a></div></div></section>
</main><Footer/>
</BaseLayout>
<style>.page{background:#0a0a0f;color:#e0dce8}.page-hero{padding:140px 0 64px;background:linear-gradient(135deg,var(--purple-bg),#2D1250);color:var(--white);text-align:center}.page-hero h1{font-family:var(--font-display);font-size:clamp(28px,5vw,48px);font-weight:800;margin-bottom:12px}.page-hero p{font-size:17px;color:#94a3b8}.section{padding:80px 0}.section-alt{background:#110d1a}.container{max-width:1100px;margin:0 auto;padding:0 24px}.section h2{font-family:var(--font-display);font-size:clamp(24px,4vw,36px);font-weight:800;color:#e0dce8;margin-bottom:32px;text-align:center}.cap-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}.cap-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px}.cap-card h3{font-size:16px;font-weight:700;color:var(--purple-light);margin-bottom:8px}.cap-card p{font-size:14px;color:#9ca3af;line-height:1.7}@media(max-width:640px){.page-hero h1{font-size:24px}}</style>
