---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
const currentPath = "/products/";
const cats = [
  {id:"food",name:"Food Packaging",desc:"FDA-compliant boxes for produce, confectionery, and food service",items:["Strawberry punnets","Chocolate boxes","Pastry packaging","Bakery boxes","Takeaway containers"],grid:["Fruit Punnet Box","Chocolate Gift Box","Pastry Window Box","Bakery Tray Box","Food Container"]},
  {id:"gift",name:"Gift Boxes",desc:"Premium rigid, magnetic, and collapsible presentation boxes",items:["Magnetic closure","Collapsible gift boxes","Drawer boxes","Jewelry boxes","Candle boxes"],grid:["Magnetic Flip Box","Drawer Gift Box","Collapsible Box","Rigid Jewelry Box","Candle Gift Set"]},
  {id:"corrugated",name:"Corrugated & Shipping",desc:"Mailer boxes and e-commerce packaging with branded interior",items:["Mailer boxes","Shipping cartons","Subscription boxes","Die-cut shapes","Branded interior"],grid:["Custom Mailer Box","Shipping Carton","Subscription Box","Die-Cut Mailer","E-Commerce Box"]},
  {id:"cosmetic",name:"Cosmetic Packaging",desc:"Luxury boxes for beauty, skincare, and fragrance brands",items:["Skincare boxes","Makeup palettes","Perfume boxes","Gift sets","Rigid cases"],grid:["Serum Box","Palette Box","Perfume Gift Box","Skincare Set Box","Rigid Cosmetic Case"]},
];
---
<BaseLayout title="Product Directory — YMBOX Packaging" description="Browse YMBOX packaging by category: food, gift, corrugated, cosmetic. Custom boxes for global brands." lang="en" currentPath={currentPath}>
<Nav lang="en" currentPath={currentPath} />
<main class="page"><section class="page-hero"><div class="container"><h1>Product Directory</h1><p>Browse by category. Every box custom made.</p></div></section>
<section class="section section-alt"><div class="dir-layout">
<nav class="dir-sidebar"><h3>Categories</h3>{cats.map((c)=>(<a href={`#${c.id}`} class="dir-link">{c.name}</a>))}<a href="/contact/" class="dir-link dir-cta">Get a Quote →</a></nav>
<div class="dir-content">{cats.map((c)=>(<section id={c.id} class="dir-section"><h2>{c.name}</h2><p class="dir-desc">{c.desc}</p><div class="dir-grid">{c.grid.map((item)=>(<div class="dir-card"><div class="dir-img"><div class="dir-ph">{item}</div></div><span>{item}</span></div>))}</div><div class="dir-features">{c.items.map((i)=>(<span class="dir-tag">{i}</span>))}</div></section>))}</div>
</div></section></main><Footer/>
</BaseLayout>
<style>.page{background:#0a0a0f;color:#e0dce8}.page-hero{padding:140px 0 64px;background:linear-gradient(135deg,var(--purple-bg),#2D1250);color:var(--white);text-align:center}.page-hero h1{font-family:var(--font-display);font-size:clamp(32px,5vw,48px);font-weight:800;margin-bottom:12px}.page-hero p{font-size:17px;color:#94a3b8}.section{padding:80px 0}.section-alt{background:#110d1a}.dir-layout{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:200px 1fr;gap:40px;padding:0 24px}.dir-sidebar{position:sticky;top:100px;align-self:start}.dir-sidebar h3{font-size:14px;font-weight:700;color:#e0dce8;margin-bottom:16px;text-transform:uppercase;letter-spacing:2px}.dir-link{display:block;padding:8px 0;font-size:14px;color:#6b7280;text-decoration:none;transition:color .2s;border-bottom:1px solid rgba(255,255,255,0.04)}.dir-link:hover{color:var(--purple-light)}.dir-cta{margin-top:12px;color:var(--purple-light)!important;font-weight:600}.dir-section{margin-bottom:64px}.dir-section h2{font-family:var(--font-display);font-size:24px;font-weight:800;color:#e0dce8;margin-bottom:8px}.dir-desc{font-size:14px;color:#9ca3af;margin-bottom:20px}.dir-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:16px}.dir-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:10px;overflow:hidden;transition:border-color .2s}.dir-card:hover{border-color:var(--purple-light)}.dir-img{height:160px;overflow:hidden}.dir-ph{height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(124,58,237,0.1),rgba(74,29,139,0.04));font-size:12px;color:rgba(124,58,237,0.3);font-weight:600;text-align:center;padding:4px}.dir-card span{display:block;padding:10px 12px;font-size:12px;color:#9ca3af}.dir-features{display:flex;flex-wrap:wrap;gap:8px}.dir-tag{padding:6px 14px;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.15);border-radius:20px;font-size:12px;color:var(--purple-light)}@media(max-width:768px){.dir-layout{grid-template-columns:1fr}.dir-sidebar{position:static;display:flex;flex-wrap:wrap;gap:12px;margin-bottom:24px}.dir-sidebar h3{display:none}.dir-link{border-bottom:none;padding:6px 12px;background:rgba(255,255,255,0.02);border-radius:6px}}@media(max-width:640px){.page-hero h1{font-size:28px}.dir-grid{grid-template-columns:repeat(2,1fr)}.dir-img{height:130px}}</style>
