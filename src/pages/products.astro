---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
const currentPath = "/products/";
const cats = [
  {id:"gift",name:"Custom Gift Boxes",desc:"Premium rigid, magnetic, drawer, and collapsible presentation boxes",imgs:[1,2,4,5,6,7,8,12,13,14,19,20,21,22,23,28,29,30,31],tags:["Magnetic closure","Drawer boxes","Collapsible","Rigid","Foil stamping","Embossing","Luxury finishes"]},
  {id:"food",name:"Food Packaging Boxes",desc:"FDA-compliant boxes for produce, confectionery, and food service",imgs:[3,9,10,11,24,25,27,32],tags:["Window boxes","Display packaging","Folding cartons","Food-grade","FDA compliant","Kraft options"]},
  {id:"cosmetic",name:"Cosmetic & Luxury Packaging",desc:"High-end boxes for beauty, skincare, fragrance, and jewelry",imgs:[15,16,26],tags:["Skincare boxes","Jewelry presentation","Velvet lining","Rigid cases","Premium finishes"]},
  {id:"corrugated",name:"Corrugated & Shipping Boxes",desc:"Mailer boxes, shipping cartons, and e-commerce packaging",imgs:[17,18],tags:["Mailer boxes","Shipping cartons","Kraft material","E-commerce ready","Branded interior"]},
];
---
<BaseLayout title="Product Gallery — YMBOX Packaging" description="Browse YMBOX custom packaging gallery. 32 box types across gift boxes, food packaging, cosmetic, and shipping. Custom manufacturing." lang="en" currentPath={currentPath}>
<Nav lang="en" currentPath={currentPath} />
<main class="page"><section class="page-hero"><div class="container"><h1>Product Gallery</h1><p>32 box types. Every one custom made for your brand.</p></div></section>
<section class="section section-alt"><div class="dir-layout">
<nav class="dir-sidebar"><h3>Categories</h3>{cats.map((c)=>(<a href={`#${c.id}`} class="dir-link">{c.name}</a>))}<a href="/contact/" class="dir-link dir-cta">Get a Quote →</a></nav>
<div class="dir-content">{cats.map((c)=>(<section id={c.id} class="dir-section"><h2>{c.name}</h2><p class="dir-desc">{c.desc}</p><div class="gallery-full">{c.imgs.map((i)=>(<div class="g-card"><img src={`/images/product-${i}.webp`} alt="Custom packaging box" loading="lazy"/></div>))}</div><div class="dir-features">{c.tags.map((t)=>(<span class="dir-tag">{t}</span>))}</div></section>))}</div>
</div></section><section class="section"><div class="container"><span class="s-label">Specifications</span><h2>What You Need to Know</h2><div class="spec-grid"><div class="spec-card"><h3>Materials</h3><ul><li>Grey Board 1200gsm — rigid luxury boxes</li><li>Coated Art Paper — glossy, high-end retail</li><li>Kraft Paper — natural, eco-friendly</li><li>Duplex Board — economical, lightweight</li><li>Corrugated E-Flute — protective shipping</li><li>Food-grade FDA / EU compliant stock</li></ul></div><div class="spec-card"><h3>Finishing Options</h3><ul><li>Hot Foil Stamping — gold, silver, holographic</li><li>Spot UV — precise glossy highlights</li><li>Matte / Gloss Lamination — smooth or shiny</li><li>Embossing & Debossing — tactile 3D effects</li><li>Soft Touch Coating — velvety feel</li><li>Die Cutting — any custom shape</li></ul></div><div class="spec-card"><h3>Box Structures</h3><ul><li>Straight Tuck End — classic retail box</li><li>Reverse Tuck End — secure closure</li><li>Magnetic Rigid Box — premium luxury</li><li>Drawer Box — sliding elegance</li><li>Mailer Box — e-commerce ready</li><li>Custom Die-Cut — your design, our precision</li></ul></div><div class="spec-card"><h3>Ordering Info</h3><ul><li>MOQ: 50 pieces per design</li><li>Sample: Free pre-production sample</li><li>Production: 7-15 days standard</li><li>Shipping: Sea / Air / DDP to door</li><li>Payment: T/T, LC, PayPal</li><li>File Format: AI, PDF, CDR accepted</li></ul></div></div></div></section></main><Footer/>
</BaseLayout>
<style>.page{background:#0a0a0f;color:#e0dce8}.page-hero{padding:140px 0 64px;background:linear-gradient(135deg,var(--purple-bg),#2D1250);color:var(--white);text-align:center}.page-hero h1{font-family:var(--font-display);font-size:clamp(32px,5vw,48px);font-weight:800;margin-bottom:12px}.page-hero p{font-size:17px;color:#94a3b8}.section{padding:80px 0}.section-alt{background:#110d1a}.dir-layout{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:200px 1fr;gap:40px;padding:0 24px}.dir-sidebar{position:sticky;top:100px;align-self:start}.dir-sidebar h3{font-size:14px;font-weight:700;color:#e0dce8;margin-bottom:16px;text-transform:uppercase;letter-spacing:2px}.dir-link{display:block;padding:8px 0;font-size:14px;color:#6b7280;text-decoration:none;transition:color .2s;border-bottom:1px solid rgba(255,255,255,0.04)}.dir-link:hover{color:var(--purple-light)}.dir-cta{margin-top:12px;color:var(--purple-light)!important;font-weight:600}.dir-section{margin-bottom:64px}.dir-section h2{font-family:var(--font-display);font-size:24px;font-weight:800;color:#e0dce8;margin-bottom:8px}.dir-desc{font-size:14px;color:#9ca3af;margin-bottom:20px}.gallery-full{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:16px}.g-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:8px;overflow:hidden;aspect-ratio:1}.g-card img{width:100%;height:100%;object-fit:cover;transition:transform .3s}.g-card:hover img{transform:scale(1.08)}.dir-features{display:flex;flex-wrap:wrap;gap:8px}.dir-tag{padding:6px 14px;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.15);border-radius:20px;font-size:12px;color:var(--purple-light)}.spec-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px}.spec-card{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:20px}.spec-card h3{font-size:15px;font-weight:700;color:var(--purple-light);margin-bottom:12px}.spec-card ul{list-style:none;padding:0}.spec-card li{font-size:13px;color:#9ca3af;padding:4px 0}.spec-card li::before{content:"- ";color:var(--purple-light)}@media(max-width:768px){.dir-layout{grid-template-columns:1fr}.dir-sidebar{position:static;display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px}.dir-sidebar h3{display:none}.dir-link{border-bottom:none;padding:6px 12px;background:rgba(255,255,255,0.02);border-radius:6px;font-size:12px}}@media(max-width:640px){.page-hero h1{font-size:28px}.gallery-full{grid-template-columns:repeat(3,1fr)}}</style>
