---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import CTASection from "../../components/CTASection.astro";
import zh from "../../i18n/zh.json";

const t = zh;
const currentPath = "/zh/about/";
---

<BaseLayout
  title={`关于我们 — ${t.site.title}`}
  description="18年包装制造经验。ISO认证工厂，5台大型印刷机，小森&罗兰设备，FDA及EU食品接触合规。中国东莞。"
  lang="zh"
  currentPath={currentPath}
>
  <Nav lang="zh" currentPath={currentPath} />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1 data-reveal="fade">{t.about.title}</h1>
        <p data-reveal="fade">{t.about.description}</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="story-layout">
            <div class="story-content" data-reveal="left">
            <span class="section-label">我们是谁</span>
            <h2 class="section-title">{t.about.story.title}</h2>
            <p>{t.about.story.content}</p>
          </div>
          <div class="story-img" data-reveal="right">
            <div class="img-placeholder">工厂实拍</div>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-bar">
      <div class="container">
        {t.about.team.items.map((item) => (
          <div class="stat-item">
            <div class="stat-num">{item.number}</div>
            <div class="stat-lbl">{item.label}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <span class="section-label">设备实力</span>
        <h2 class="section-title">{t.about.machinery.title}</h2>
        <p class="section-desc">从印前到后道，全流程自有设备完成</p>
        <div class="machinery-grid" data-reveal-stagger="120">
          {t.about.machinery.items.map((item) => (
            <div class="machinery-card hover-lift glow-hover" data-reveal>
              <h3>{item.name}</h3>
              <p>{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <span class="section-label">信任与品质</span>
        <h2 class="section-title">{t.about.certifications.title}</h2>
        <div class="cert-grid" data-reveal-stagger="150">
          {t.about.certifications.items.map((item) => (
            <div class="cert-card hover-lift glow-hover" data-reveal>
              <div class="cert-icon">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                  <circle cx="20" cy="20" r="18" stroke="var(--purple)" stroke-width="2"/>
                  <path d="M12 20L18 26L28 14" stroke="var(--purple)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="cert-content">
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      lang="zh"
      title="想参观我们的工厂？"
      description="我们欢迎客户来访。联系我们预约工厂参观或索取详细设备参数。"
      buttonText="预约参观"
    />
  </main>

  <Footer lang="zh" />
</BaseLayout>

<style>
  .page-hero {
    padding: 140px 0 64px;
    background: linear-gradient(135deg, var(--purple-bg), #2D1250);
    color: var(--white);
    text-align: center;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .page-hero p {
    font-size: 17px;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto;
  }

  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .story-content p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: 16px;
  }

  .img-placeholder {
    background: linear-gradient(135deg, #f0edf7, #e8e0f5);
    border-radius: var(--radius-lg);
    height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple);
    font-weight: 600;
    font-size: 15px;
  }

  .stats-bar {
    background: var(--purple);
    padding: 48px 0;
  }

  .stats-bar .container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 6px;
  }

  .stat-lbl {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  .machinery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }

  .machinery-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 28px;
    transition: box-shadow 0.2s;
  }

  .machinery-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--purple-light);
  }

  .machinery-card h3 {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--purple-deep);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .machinery-card h3::before {
    content: "⚙";
    font-size: 18px;
  }

  .machinery-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }

  .cert-card {
    display: flex;
    gap: 16px;
    background: var(--purple-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 24px;
    transition: box-shadow 0.2s;
  }

  .cert-card:hover {
    box-shadow: var(--shadow-sm);
  }

  .cert-icon {
    flex-shrink: 0;
    padding-top: 2px;
  }

  .cert-content h3 {
    font-size: 16px;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .cert-content p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .page-hero h1 {
      font-size: 28px;
    }

    .stats-bar .container {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .stat-num {
      font-size: 32px;
    }
  }
</style>
